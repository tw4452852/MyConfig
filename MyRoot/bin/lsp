#!/usr/bin/env janet

(import spork)
(use spork/sh-dsl)

(def supported {:c {:cmd ["clangd" "-log=error"] :root "compile_commands.json"}})

(defn get-type
  [filepath]
  (def ext (spork/path/ext filepath))
  (def type (cond
              (has-value? [".c" ".cpp" ".h" ".hpp" ".cc"] ext)
              :c
              (errorf "unknown type for %s" filepath)))
  (unless (has-key? supported type)
    (errorf "type %v not supported yet"))

  type)

(defn get-project-root
  [filepath]
  (def type (get-type filepath))
  (def target ((in supported type) :root))
  (var cur-dir (spork/path/dirname filepath))
  (while (= nil (os/stat (spork/path/join cur-dir target)))
    (if (= "/" cur-dir) (errorf "can't find project root for %s" filepath))
    (set cur-dir (spork/path/parent cur-dir)))
  cur-dir)


(defn get-sock-path
  [project-root]
  (string "/tmp/lsp" (hash project-root) ".sock"))

## Server

(defn- read-to-crln
  [stream]
  (def buf @"")
  (while (not (string/has-suffix? "\r\n" buf))
    (ev/chunk stream 1 buf))
  buf)

(defn- json-encode
  [x]
  (def buf (spork/json/encode x))
  (string/format "Content-Length: %d\r\n\r\n%s" (length buf) buf))

# Display in LSP window
(defn- show
  [x]
  (def l ($<_ :9p read acme/index |grep -m 1 -e +LSP |awk "{print $1}"))
  (def winid (cond
               (and (= :buffer (type l)) (not (empty? l)))
               l
               (do
                 (def _winid ($<_ :9p read acme/new/ctl |awk "{print $1}"))
                 ($ echo name +LSP |:9p write ,(string "acme/" _winid "/ctl"))
                 _winid)))
  ($ printf "%s" ,x |:9p write ,(string "acme/" winid "/body")))

(defn server
  [args]

  (var id 0)
  (def pending @{})
  (def proc (os/spawn args :p {:in :pipe :out :pipe}))
  (defer (os/proc-close proc)
    (def fns
      {:def (fn [self f l c]
              (++ id)
              (put pending id (string/format "\ndef %s:%d %s" f (inc l) ($< sed -n ,(string (inc l) "p") ,f)))
              (->> {:jsonrpc "2.0"
                    :id id
                    :method "textDocument/definition"
                    :params {:textDocument {:uri (string "file://" f)}
                             :position {:line l :character c}}} json-encode (ev/write (proc :in))))

       :refs (fn [self f l c]
               (++ id)
               (put pending id (string/format "\nrefs %s:%d %s" f (inc l) ($< sed -n ,(string (inc l) "p") ,f)))
               (->> {:jsonrpc "2.0"
                     :id id
                     :method "textDocument/references"
                     :params {:textDocument {:uri (string "file://" f)}
                              :position {:line l :character c}
                              :context {:includeDeclaration true}}} json-encode (ev/write (proc :in))))

       :open (fn [self f winid]
               (->> {:jsonrpc "2.0"
                     :method "textDocument/didOpen"
                     :params {:textDocument {:uri (string "file://" f)
                                             :languageId (string (get-type f))
                                             :version 0
                                             :text ($< :9p read ,(string "acme/" winid "/body"))}}} json-encode (ev/write (proc :in))))})

    (def root (os/cwd))
    (def sock-path (get-sock-path root))
    (protect (os/rm sock-path))
    (printf "Listen on %s" sock-path)
    (with [s (spork/rpc/server fns :unix sock-path)]

      (->> {:jsonrpc "2.0"
            :id (++ id)
            :method "initialize"
            :params {:rootUri (string "file://" root)
                     :processId (os/getpid)
                     :capabilities {:general {:positionEncodings ["utf-8"]}}}} json-encode (ev/write (proc :in)))

      (->> {:jsonrpc "2.0"
            :method "initialized"
            :params {}} json-encode (ev/write (proc :in)))

      (forever
        (def in (proc :out))
        (def l (read-to-crln in))
        (def n (scan-number (string/slice l 16 -3)))
        (assertf n "can't retrieve content length from \"%s\"" l)
        (read-to-crln in)
        (def content (spork/json/decode (ev/chunk in n)))
        (if-let [rid (get content "id") req (get pending rid)]
          (do
            (show req)
            (if-let [result (get content "result")]
              (cond
                (= :array (type result))
                (show (reduce (fn [acc el]
                                (def f (string/slice (el "uri") (length "file://")))
                                (def l (get-in el ["range" "start" "line"]))
                                (string/format "%s%s:%d %s" acc f (inc l) ($< sed -n ,(string (inc l) "p") ,f))) @"" result)))

              (do
                (def f (string/slice (result "uri") (length "file://")))
                (def l (get-in result ["range" "start" "line"]))
                (show (string/format "%s:%d %s" f (inc l) ($< sed -n ,(string (inc l) "p") ,f)))))
            (put pending rid nil))
          (pp content))))))

## Main

(defn- get-server
  [filepath]
  (def project-root (get-project-root filepath))
  (def sock-path (get-sock-path project-root))
  (def (success stream) (protect (net/connect :unix sock-path)))
  (if success
    (do (:close stream) (spork/rpc/client :unix sock-path))
    (do
      (def cmd ((supported (get-type filepath)) :cmd))
      ($ tmux new -d -s ,project-root -c ,project-root ,((dyn :args) 0) server ,;cmd)
      (ev/sleep 1)
      (spork/rpc/client :unix sock-path))))

(defn main
  [self cmd & args]

  (cond
    (= cmd "server")
    (server args)

    (or (= cmd "def") (= cmd "refs"))
    (do
      (def filepath (os/getenv "samfile"))
      (assertf filepath "samfile environment variable not set?")
      (def l (scan-number (get args 0)))
      (def c (scan-number (get args 1)))
      (assertf (and l c) "line and colum not set?")
      (def winid (os/getenv "winid"))
      (assertf winid "winid not set?")
      (with [s (get-server filepath)]
        (:open s filepath winid)
        ((keyword cmd) s filepath l c)))

    (errorf "unknown args: %P" (dyn :args))))
